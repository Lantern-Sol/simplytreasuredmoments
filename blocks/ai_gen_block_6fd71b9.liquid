{% doc %}
  @prompt
    Generate Icon with Text block add upto 3. icon image on left and text on right , alignment should be horizontal 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-text-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-icon-text-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    gap: {{ block.settings.spacing_between_items }}px;
    flex-wrap: wrap;
  }

  .ai-icon-text-item-{{ ai_gen_id }} {
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    gap: {{ block.settings.spacing_between_icon_text }}px;
    flex: 1;
    min-width: 200px;
  }

  .ai-icon-text-icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-text-icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-icon-text-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_background }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-text-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-icon-text-content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-icon-text-title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
  }

  .ai-icon-text-description-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-text-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-icon-text-container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-icon-text-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<icon-text-{{ ai_gen_id }} class="ai-icon-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-text-container-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign enabled_key = 'item_' | append: i | append: '_enabled'
        assign icon_key = 'item_' | append: i | append: '_icon'
        assign title_key = 'item_' | append: i | append: '_title'
        assign description_key = 'item_' | append: i | append: '_description'

        assign enabled = block.settings[enabled_key]
        assign icon = block.settings[icon_key]
        assign title = block.settings[title_key]
        assign description = block.settings[description_key]
      %}

      {% if enabled %}
        <div class="ai-icon-text-item-{{ ai_gen_id }}">
          <div class="ai-icon-text-icon-wrapper-{{ ai_gen_id }}">
            {% if icon %}
              <img
                src="{{ icon | image_url: width: 200 }}"
                alt="{{ title | escape }}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <div class="ai-icon-text-icon-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-icon-text-content-{{ ai_gen_id }}">
            {% if title != blank %}
              <h3 class="ai-icon-text-title-{{ ai_gen_id }}">{{ title }}</h3>
            {% endif %}
            {% if description != blank %}
              <div class="ai-icon-text-description-{{ ai_gen_id }}">{{ description }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</icon-text-{{ ai_gen_id }}>

<script>
  (function() {
    class IconText{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('icon-text-{{ ai_gen_id }}', IconText{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Icon with text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "spacing_between_items",
      "label": "Spacing between items",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_between_icon_text",
      "label": "Spacing between icon and text",
      "min": 5,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "icon_border_radius",
      "label": "Icon border radius",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "placeholder_background",
      "label": "Placeholder background",
      "default": "#f4f4f4"
    },
    {
      "type": "header",
      "content": "Title style"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Title weight",
      "options": [
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Title spacing",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Description style"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#2f2f2f"
    },
    {
      "type": "header",
      "content": "Item 1"
    },
    {
      "type": "checkbox",
      "id": "item_1_enabled",
      "label": "Enable item 1",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "item_1_icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "item_1_title",
      "label": "Title",
      "default": "Free shipping"
    },
    {
      "type": "textarea",
      "id": "item_1_description",
      "label": "Description",
      "default": "On orders over $50"
    },
    {
      "type": "header",
      "content": "Item 2"
    },
    {
      "type": "checkbox",
      "id": "item_2_enabled",
      "label": "Enable item 2",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "item_2_icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "item_2_title",
      "label": "Title",
      "default": "Easy returns"
    },
    {
      "type": "textarea",
      "id": "item_2_description",
      "label": "Description",
      "default": "30-day return policy"
    },
    {
      "type": "header",
      "content": "Item 3"
    },
    {
      "type": "checkbox",
      "id": "item_3_enabled",
      "label": "Enable item 3",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "item_3_icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "item_3_title",
      "label": "Title",
      "default": "Secure checkout"
    },
    {
      "type": "textarea",
      "id": "item_3_description",
      "label": "Description",
      "default": "Safe and encrypted payment"
    }
  ],
  "presets": [
    {
      "name": "Icon with text"
    }
  ]
}
{% endschema %}
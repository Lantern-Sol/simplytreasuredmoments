{% doc %}
  @prompt
    “Who We Are” section consisting of three paragraphs, and also create a “Why Choose Us” section featuring a list of points—each with a title and a brief one-line description.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-why-choose-us-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-why-choose-us__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-why-choose-us__list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-why-choose-us__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.title_description_spacing }}px;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
  }

  .ai-why-choose-us__item-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-why-choose-us__item-description-{{ ai_gen_id }} {
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    line-height: {{ block.settings.line_height }};
    margin: 0;
    text-align: {{ block.settings.text_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-why-choose-us-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-why-choose-us__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-why-choose-us__item-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-why-choose-us__item-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-why-choose-us-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-why-choose-us__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <ul class="ai-why-choose-us__list-{{ ai_gen_id }}">
    {% if block.settings.item_1_title != blank %}
      <li class="ai-why-choose-us__item-{{ ai_gen_id }}">
        <h3 class="ai-why-choose-us__item-title-{{ ai_gen_id }}">{{ block.settings.item_1_title }}</h3>
        {% if block.settings.item_1_description != blank %}
          <p class="ai-why-choose-us__item-description-{{ ai_gen_id }}">{{ block.settings.item_1_description }}</p>
        {% endif %}
      </li>
    {% endif %}

    {% if block.settings.item_2_title != blank %}
      <li class="ai-why-choose-us__item-{{ ai_gen_id }}">
        <h3 class="ai-why-choose-us__item-title-{{ ai_gen_id }}">{{ block.settings.item_2_title }}</h3>
        {% if block.settings.item_2_description != blank %}
          <p class="ai-why-choose-us__item-description-{{ ai_gen_id }}">{{ block.settings.item_2_description }}</p>
        {% endif %}
      </li>
    {% endif %}

    {% if block.settings.item_3_title != blank %}
      <li class="ai-why-choose-us__item-{{ ai_gen_id }}">
        <h3 class="ai-why-choose-us__item-title-{{ ai_gen_id }}">{{ block.settings.item_3_title }}</h3>
        {% if block.settings.item_3_description != blank %}
          <p class="ai-why-choose-us__item-description-{{ ai_gen_id }}">{{ block.settings.item_3_description }}</p>
        {% endif %}
      </li>
    {% endif %}

    {% if block.settings.item_4_title != blank %}
      <li class="ai-why-choose-us__item-{{ ai_gen_id }}">
        <h3 class="ai-why-choose-us__item-title-{{ ai_gen_id }}">{{ block.settings.item_4_title }}</h3>
        {% if block.settings.item_4_description != blank %}
          <p class="ai-why-choose-us__item-description-{{ ai_gen_id }}">{{ block.settings.item_4_description }}</p>
        {% endif %}
      </li>
    {% endif %}

    {% if block.settings.item_5_title != blank %}
      <li class="ai-why-choose-us__item-{{ ai_gen_id }}">
        <h3 class="ai-why-choose-us__item-title-{{ ai_gen_id }}">{{ block.settings.item_5_title }}</h3>
        {% if block.settings.item_5_description != blank %}
          <p class="ai-why-choose-us__item-description-{{ ai_gen_id }}">{{ block.settings.item_5_description }}</p>
        {% endif %}
      </li>
    {% endif %}
     {% if block.settings.item_6_title != blank %}
      <li class="ai-why-choose-us__item-{{ ai_gen_id }}">
        <h3 class="ai-why-choose-us__item-title-{{ ai_gen_id }}">{{ block.settings.item_6_title }}</h3>
        {% if block.settings.item_6_description != blank %}
          <p class="ai-why-choose-us__item-description-{{ ai_gen_id }}">{{ block.settings.item_6_description }}</p>
        {% endif %}
      </li>
    {% endif %}
     {% if block.settings.item_7_title != blank %}
      <li class="ai-why-choose-us__item-{{ ai_gen_id }}">
        <h3 class="ai-why-choose-us__item-title-{{ ai_gen_id }}">{{ block.settings.item_7_title }}</h3>
        {% if block.settings.item_7_description != blank %}
          <p class="ai-why-choose-us__item-description-{{ ai_gen_id }}">{{ block.settings.item_7_description }}</p>
        {% endif %}
      </li>
    {% endif %}
  </ul>
</div>


<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@700&family=Nunito+Sans:ital,wght@0,400;1,400&display=swap');

  .ls-faq-hero {
    position: relative;
    overflow: hidden;
  }

  .ls-faq-hero__bg {
    position: absolute;
    inset: 0;
    grid-column: 1 / -1;
    grid-row: 1 / -1;
    z-index: 0;
  }

  .ls-faq-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ls-faq-hero__overlay {
    position: absolute;
    inset: 0;
  }

  .ls-faq-hero__inner {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 43.625rem;
    margin: 0 auto;
    padding-top: var(--ls-hero-offset, 217px);
    padding-bottom: var(--desktop-pb, 28px);
    position: relative;
    z-index: 1;
  }

  .ls-faq-hero__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    font-size: 2.75rem;
    line-height: 3.025rem;
    color: #192534;
    margin: 0 0 0.3125rem;
  }

  .ls-faq-hero__subtitle {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    font-size: 1.125rem;
    line-height: 1.6875rem;
    color: #192534;
    margin: 0 0 1.75rem;
  }

  .ls-faq-hero__search {
    display: flex;
    gap: 0.5rem;
    width: 100%;
    max-width: 43.625rem;
    justify-content: center;
  }

  .ls-faq-hero__input {
    width: 39.5rem;
    max-width: 100%;
    height: 3.5625rem;
    border: 1px solid #AEB2B8;
    border-radius: 0.5rem;
    box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);
    padding: 0 1rem;
    font-family: 'Nunito Sans', sans-serif;
    font-size: 1rem;
    color: #192534;
    outline: none;
    background: #FFFEFD;
  }

  .ls-faq-hero__input::placeholder {
    color: #BCC6D2;
  }

  .ls-faq-hero__input:focus {
    border-color: #192534;
  }

  .ls-faq-hero__search-btn {
    width: 3.5625rem;
    height: 3.5625rem;
    flex-shrink: 0;
    border: 1px solid #AEB2B8;
    border-radius: 0.5rem;
    box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);
    background: #FFFEFD;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s ease;
  }

  .ls-faq-hero__search-btn:hover {
    border-color: #192534;
  }

  .ls-faq-hero__search-btn svg {
    width: 1.9375rem;
    height: 1.9375rem;
  }

  .ls-faq-hero__no-results {
    display: none;
    font-family: 'Nunito Sans', sans-serif;
    font-size: 1rem;
    color: #6b7280;
    text-align: center;
    padding: 2rem 1rem;
  }

  @media (max-width: 749px) {
    .ls-faq-hero__inner {
      padding-top: var(--ls-hero-offset, 140px);
      padding-bottom: var(--mobile-pb, 24px);
      padding-inline: 0;
    }

    .ls-faq-hero__search {
      flex-direction: row;
      width: 100%;
    }

    .ls-faq-hero__input {
      width: 100%;
      flex: 1;
    }
  }
</style>

<section
  class="section section--full-width ls-faq-hero"
  style="
    --desktop-pt: {{ section.settings.padding_top }}px;
    --desktop-pb: {{ section.settings.padding_bottom }}px;
    --mobile-pt: {{ section.settings.mobile_padding_top }}px;
    --mobile-pb: {{ section.settings.mobile_padding_bottom }}px;
    background-color: #FFFEFD;
  "
>
  {%- if section.settings.background_image != blank -%}
    <div class="ls-faq-hero__bg">
      {{ section.settings.background_image | image_url: width: 1920 | image_tag: loading: 'lazy', sizes: '100vw' }}
      {%- if section.settings.overlay_opacity > 0 -%}
        <div class="ls-faq-hero__overlay" style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="ls-faq-hero__inner">
    <h1 class="ls-faq-hero__heading">{{ section.settings.heading }}</h1>
    <p class="ls-faq-hero__subtitle">{{ section.settings.subtitle }}</p>

    <div class="ls-faq-hero__search">
      <input
        type="text"
        class="ls-faq-hero__input"
        placeholder="{{ section.settings.placeholder | escape }}"
        aria-label="Search FAQ questions"
      >
      <button class="ls-faq-hero__search-btn" type="button" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="31" height="31" viewBox="0 0 31 31" fill="none">
          <path d="M26.868 26.0667L19.8763 19.075C21.2306 17.4022 22.0461 15.2765 22.0461 12.9613C22.0461 7.59536 17.6799 3.22925 12.314 3.22925C6.94809 3.22925 2.58203 7.59531 2.58203 12.9612C2.58203 18.3272 6.94814 22.6933 12.3141 22.6933C14.6292 22.6933 16.7549 21.8778 18.4278 20.5235L25.4195 27.5152C25.6193 27.715 25.8815 27.8154 26.1438 27.8154C26.4061 27.8154 26.6683 27.715 26.8681 27.5152C27.2686 27.1147 27.2686 26.4672 26.868 26.0667ZM12.3141 20.6444C8.07704 20.6444 4.63089 17.1983 4.63089 12.9612C4.63089 8.72421 8.07704 5.27806 12.3141 5.27806C16.5511 5.27806 19.9972 8.72421 19.9972 12.9612C19.9972 17.1983 16.551 20.6444 12.3141 20.6444Z" fill="#C8A45D"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  // Measure actual header height and set hero offset dynamically
  (function() {
    var header = document.querySelector('.header');
    var inner = document.querySelector('.ls-faq-hero__inner');
    if (header && inner) {
      var gap = 16;
      var offset = header.offsetHeight + gap;
      inner.style.setProperty('--ls-hero-offset', offset + 'px');
    }
  })();

  (function() {
    var section = document.querySelector('.ls-faq-hero');
    if (!section) return;

    var input = section.querySelector('.ls-faq-hero__input');
    var btn = section.querySelector('.ls-faq-hero__search-btn');
    var debounceTimer;

    function filterFaq() {
      var query = input.value.trim().toLowerCase();
      var items = document.querySelectorAll('.ls-faq__item');

      if (!items.length) return;

      var visibleCount = 0;

      items.forEach(function(item) {
        var summary = item.querySelector('summary');
        var answer = item.querySelector('.ls-faq__answer');
        var questionText = summary ? summary.textContent.toLowerCase() : '';
        var answerText = answer ? answer.textContent.toLowerCase() : '';

        if (!query || questionText.indexOf(query) !== -1 || answerText.indexOf(query) !== -1) {
          item.style.display = '';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });

      var noResults = document.querySelector('.ls-faq-hero__no-results');
      if (noResults) {
        noResults.style.display = (query && visibleCount === 0) ? 'block' : 'none';
      }
    }

    function debounceFilter() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(filterFaq, 200);
    }

    input.addEventListener('input', debounceFilter);

    btn.addEventListener('click', function() {
      input.focus();
      filterFaq();
    });

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        filterFaq();
      }
    });

    // Insert no-results message after the FAQ list
    var faqList = document.querySelector('.ls-faq__list');
    if (faqList) {
      var noResults = document.createElement('p');
      noResults.className = 'ls-faq-hero__no-results';
      noResults.textContent = 'No questions match your search. Try a different term.';
      faqList.parentNode.insertBefore(noResults, faqList.nextSibling);
    }
  })();
</script>

{% schema %}
{
  "name": "LS FAQ Hero",
  "tag": "section",
  "class": "ls-faq-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everything you want to know before you buy"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Most common questions answered. If yours isn't here, we're one message away."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Search placeholder",
      "default": "Search questions. Try \"personalization\" or \"return policy\""
    },
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "LS FAQ Hero"
    }
  ]
}
{% endschema %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500&family=Nunito+Sans:wght@400;600;700&display=swap');

  .ls-story__inner {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    border-radius: 0.625rem;
    overflow: hidden;
    background-color: #FAFAFA;
    max-width: 70.25rem;
    margin: 0 auto;
    width: 100%;
  }

  .ls-story__image-wrap {
    width: 341px;
    height: 455px;
    margin: 0 auto;
    overflow: hidden;
  }

  .ls-story__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ls-story__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1.5rem;
    gap: 1.875rem;
    max-width: 360px;
    margin: 0 auto;
  }

  .ls-story__text-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ls-story__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 1.75rem;
    line-height: 1.2;
    color: #192534;
    text-transform: capitalize;
    margin: 0;
  }

  .ls-story__body {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    color: #192534;
    margin: 0;
  }

  .ls-story__btn {
    display: block;
    width: 100%;
    max-width: 18.5rem;
    padding: 0.75rem 1.5rem;
    background-color: #C8A45D;
    color: #FAFAFA;
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    line-height: 1.4;
    text-align: center;
    text-decoration: none;
    border: none;
    border-radius: 0.1875rem;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .ls-story__btn:hover {
    opacity: 0.9;
  }

  @media (max-width: 749px) {
    .ls-story {
      padding-top: var(--mobile-pt) !important;
      padding-bottom: var(--mobile-pb) !important;
    }
  }

  /* Desktop */
  @media (min-width: 60em) {
    .ls-story__inner {
      flex-direction: row;
      min-height: 24rem;
    }

    .ls-story__image-wrap {
      width: 50.7%;
      height: auto;
      flex-shrink: 0;
      margin: 0;
      min-height: 100%;
    }

    .ls-story__content {
      width: 45%;
      padding: 3rem 0;
    }

    .ls-story__heading {
      font-size: 2rem;
      line-height: 1.15;
    }
  }
</style>

<section
  class="section section--full-width ls-story"
  style="
    --desktop-pt: {{ section.settings.padding_top }}px;
    --desktop-pb: {{ section.settings.padding_bottom }}px;
    --mobile-pt: {{ section.settings.mobile_padding_top }}px;
    --mobile-pb: {{ section.settings.mobile_padding_bottom }}px;
    padding-top: var(--desktop-pt);
    padding-bottom: var(--desktop-pb);
  "
>
  <div class="ls-story__inner">
    <div class="ls-story__image-wrap">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            widths: '375, 750, 1200',
            sizes: '(min-width: 60em) 55vw, 100vw',
            loading: 'lazy',
            alt: section.settings.heading
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    <div class="ls-story__content">
      <div class="ls-story__text-group">
        {%- if section.settings.heading != blank -%}
          <h2 class="ls-story__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subtext != blank -%}
          <p class="ls-story__body">{{ section.settings.subtext }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="ls-story__btn"
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "LS Story",
  "tag": "section",
  "class": "ls-story-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Handcrafted In The USA. One Keepsake At A Time."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Body text",
      "default": "Every keepsake is UV-printed with 1,440 vivid colors and assembled by hand in our USA workshop—so each piece carries the weight and warmth of something truly made with care."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "LS Story"
    }
  ]
}
{% endschema %}

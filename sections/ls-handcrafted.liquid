<style>
  @import url('https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700&display=swap');

  .section.ls-handcrafted {
    position: relative;
    overflow: hidden;
    min-height: 20rem;
  }

  .ls-handcrafted__media {
    grid-column: 1 / -1;
    grid-row: 1 / -1;
    z-index: 0;
    position: relative;
    overflow: hidden;
  }

  .ls-handcrafted__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ls-handcrafted__content {
    grid-column: 2;
    grid-row: 1 / -1;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 0;
  }

  .ls-handcrafted__card {
    background-color: #FFFFFF;
    border-radius: 0.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.1875rem 1.5rem 1.8125rem;
    width: 100%;
    max-width: 29.1875rem;
    gap: 0;
  }

  .ls-handcrafted__heading {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 600;
    font-size: 1.375rem;
    line-height: 1.7875rem;
    color: #192534;
    margin: 0;
  }

  .ls-handcrafted__text {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    font-size: 0.9375rem;
    line-height: 1.25rem;
    color: #192534;
    margin: 0.75rem 0 0;
  }

  .ls-handcrafted__form {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    margin-top: 0.75rem;
    gap: 0.5rem;
  }

  .ls-handcrafted__input {
    width: 100%;
    max-width: 18.625rem;
    height: 2.75rem;
    border-radius: 0.5rem;
    border: 0.5px solid #192534;
    padding: 0 0.875rem;
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    font-size: 0.875rem;
    color: #192534;
    background: #FFFFFF;
    outline: none;
    box-sizing: border-box;
  }

  .ls-handcrafted__input::placeholder {
    color: #6A5D4D;
  }

  .ls-handcrafted__input:focus {
    border-color: #C8A45D;
  }

  .ls-handcrafted__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 18.625rem;
    height: 2.75rem;
    background-color: #C8A45D;
    color: #FAFAFA;
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    text-decoration: none;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease;
    letter-spacing: 0.02em;
  }

  .ls-handcrafted__cta:hover {
    background-color: #b8943d;
    color: #FAFAFA;
  }

  .ls-handcrafted__message {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.8125rem;
    margin-top: 0.5rem;
  }

  .ls-handcrafted__message--success {
    color: #2e7d32;
  }

  .ls-handcrafted__message--error {
    color: #c62828;
  }

  @media (max-width: 749px) {
    .section.ls-handcrafted {
      padding-top: var(--mobile-pt) !important;
      padding-bottom: var(--mobile-pb) !important;
      min-height: 37.5rem;
    }

    .ls-handcrafted__content {
      align-items: flex-end;
      padding: 0 0.5rem 1.875rem;
    }

    .ls-handcrafted__card {
      background-color: #FAFAFA;
    }
  }

  /* Desktop */
  @media (min-width: 60em) {
    .section.ls-handcrafted {
      min-height: 25rem;
    }

    .ls-handcrafted__content {
      justify-content: flex-end;
      padding: 2.5rem 0;
      padding-right: 2.3125rem;
    }

    .ls-handcrafted__card {
      width: 29.1875rem;
    }
  }
</style>

<section
  class="section section--full-width ls-handcrafted color-{{ section.settings.color_scheme }}"
  style="
    --desktop-pt: {{ section.settings.padding_top }}px;
    --desktop-pb: {{ section.settings.padding_bottom }}px;
    --mobile-pt: {{ section.settings.mobile_padding_top }}px;
    --mobile-pb: {{ section.settings.mobile_padding_bottom }}px;
    padding-top: var(--desktop-pt);
    padding-bottom: var(--desktop-pb);
  "
>
  <div class="ls-handcrafted__media">
    {%- if section.settings.image != blank -%}
      <picture>
        {%- if section.settings.image_mobile != blank -%}
          <source
            media="(max-width: 39.9375em)"
            srcset="{{ section.settings.image_mobile | image_url: width: 780 }} 390w,
                    {{ section.settings.image_mobile | image_url: width: 1080 }} 540w,
                    {{ section.settings.image_mobile | image_url: width: 1440 }} 720w"
            sizes="100vw"
          >
        {%- endif -%}
        {{
          section.settings.image
          | image_url: width: 1920
          | image_tag:
            widths: '720, 1080, 1440, 1920',
            sizes: '100vw',
            loading: 'lazy',
            alt: section.settings.heading
        }}
      </picture>
    {%- else -%}
      <div style="width: 100%; height: 100%; background-color: #E5E3E0;"></div>
    {%- endif -%}
  </div>

  <div class="ls-handcrafted__content">
    <div class="ls-handcrafted__card">
      {%- if section.settings.heading != blank -%}
        <h2 class="ls-handcrafted__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="ls-handcrafted__text">{{ section.settings.subtext }}</p>
      {%- endif -%}

      {%- form 'customer', id: 'ls-handcrafted-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="ls-handcrafted__form">
          <input
            class="ls-handcrafted__input"
            type="email"
            name="contact[email]"
            placeholder="{{ section.settings.input_placeholder }}"
            required
            autocomplete="email"
            aria-label="{{ section.settings.input_placeholder }}"
            {% if form.posted_successfully? %}disabled{% endif %}
          >
          <button
            type="submit"
            class="ls-handcrafted__cta"
            {% if form.posted_successfully? %}disabled{% endif %}
          >
            {{ section.settings.button_label }}
          </button>
        </div>

        {%- if form.posted_successfully? -%}
          <p class="ls-handcrafted__message ls-handcrafted__message--success">
            Thanks for subscribing!
          </p>
        {%- endif -%}
        {%- if form.errors -%}
          <p class="ls-handcrafted__message ls-handcrafted__message--error">
            {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "LS Newsletter Signup",
  "tag": "section",
  "class": "ls-handcrafted-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image (optional)"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-ls-hero"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 10% off your first keepsake"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Plus gift ideas, new arrivals, and occasions worth remembering."
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get 10% Off"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "LS Newsletter Signup"
    }
  ]
}
{% endschema %}

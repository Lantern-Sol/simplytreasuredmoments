<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500&family=Nunito+Sans:wght@400;600;700&display=swap');

  .ls-cg__inner {
    grid-column: 2;
  }

  .ls-cg__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .ls-cg__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 1.5rem;
    line-height: 1.15;
    color: #192534;
    text-transform: capitalize;
    margin: 0;
  }

  .ls-cg__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    color: #192534;
    text-decoration: none;
    border: 1px solid #192534;
    background: transparent;
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    transition: background-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .ls-cg__button:hover {
    background-color: #192534;
    color: #fff;
  }

  .ls-cg__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.625rem;
  }

  .ls-cg__card {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    display: block;
    text-decoration: none;
    aspect-ratio: 1 / 1;
  }

  .ls-cg__card--large {
    grid-column: span 2;
    aspect-ratio: 2 / 1;
  }

  .ls-cg__card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .ls-cg__card:hover .ls-cg__card-img {
    transform: scale(1.04);
  }

  .ls-cg__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.45) 0%, transparent 50%);
    pointer-events: none;
  }

  .ls-cg__card-text {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 1rem;
    z-index: 1;
  }

  .ls-cg__card-title {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    line-height: 1.3;
    color: #fff;
    margin: 0;
  }

  .ls-cg__card-subtitle {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    font-style: italic;
    font-size: 0.75rem;
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.85);
    margin: 0.125rem 0 0;
  }

  @media (max-width: 749px) {
    .ls-cg {
      padding-top: var(--mobile-pt) !important;
      padding-bottom: var(--mobile-pb) !important;
    }
  }

  /* Mobile horizontal scroll */
  @media (max-width: 749px) {
    .ls-cg__inner {
      grid-column: 1 / -1;
      padding-left: var(--page-margin, 15px);
    }

    .ls-cg__header {
      flex-direction: column;
      align-items: center;
      padding-right: var(--page-margin, 15px);
    }

    .ls-cg__heading {
      text-align: center;
      max-width: 14ch;
      margin-left: auto;
      margin-right: auto;
    }

    .ls-cg__grid {
      display: flex;
      gap: 15px;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-right: var(--page-margin, 15px);
    }

    .ls-cg__grid::-webkit-scrollbar {
      display: none;
    }

    .ls-cg__card,
    .ls-cg__card--large,
    .ls-cg__card--medium,
    .ls-cg__card--small {
      flex: 0 0 70%;
      scroll-snap-align: start;
      aspect-ratio: 268 / 345;
      grid-column: unset;
    }

    .ls-cg__pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      padding-top: 1rem;
      padding-right: var(--page-margin, 15px);
    }

    .ls-cg__pagination-btn {
      background: none;
      border: none;
      padding: 0.5rem;
      cursor: pointer;
      color: #192534;
      display: flex;
      align-items: center;
    }

    .ls-cg__pagination-counter {
      font-family: 'Nunito Sans', sans-serif;
      font-weight: 600;
      font-size: 0.6875rem;
      color: #192534;
    }

    .ls-cg__mobile-cta {
      display: block;
      padding-right: var(--page-margin, 15px);
      margin-top: 1rem;
    }

    .ls-cg__mobile-cta .ls-cg__button {
      width: 100%;
    }

    .ls-cg__header .ls-cg__button {
      display: none;
    }
  }

  /* Desktop */
  @media (min-width: 60em) {
    .ls-cg__header {
      margin-bottom: 1.5rem;
    }

    .ls-cg__heading {
      font-size: 2rem;
      line-height: 2.3rem;
    }

    .ls-cg__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0.9375rem;
    }

    .ls-cg__card--large {
      grid-column: span 2;
      grid-row: span 2;
      aspect-ratio: auto;
    }

    .ls-cg__card-title {
      font-size: 1rem;
    }

    .ls-cg__card-subtitle {
      font-size: 0.8125rem;
    }

    .ls-cg__card-text {
      padding: 1.25rem;
    }

    .ls-cg__pagination,
    .ls-cg__mobile-cta {
      display: none;
    }
  }
</style>

<section
  class="section section--full-width ls-cg"
  style="
    --desktop-pt: {{ section.settings.padding_top }}px;
    --desktop-pb: {{ section.settings.padding_bottom }}px;
    --mobile-pt: {{ section.settings.mobile_padding_top }}px;
    --mobile-pb: {{ section.settings.mobile_padding_bottom }}px;
    padding-top: var(--desktop-pt);
    padding-bottom: var(--desktop-pb);
  "
>
  <div class="ls-cg__inner">
    <div class="ls-cg__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="ls-cg__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          class="ls-cg__button"
          href="{{ section.settings.button_link }}"
          {% if section.settings.button_link == blank %}role="link" aria-disabled="true"{% endif %}
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="ls-cg__grid">
      {%- for block in section.blocks -%}
        <a
          class="ls-cg__card ls-cg__card--{{ block.settings.size }}"
          href="{{ block.settings.link }}"
          {{ block.shopify_attributes }}
          {% if block.settings.link == blank %}role="link" aria-disabled="true"{% endif %}
        >
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1280
              | image_tag:
                class: 'ls-cg__card-img',
                widths: '360, 540, 720, 960, 1280',
                sizes: '(min-width: 60em) 25vw, 70vw',
                loading: 'lazy',
                alt: block.settings.title
            }}
          {%- else -%}
            <div class="ls-cg__card-img" style="background: #E5E3E0;"></div>
          {%- endif -%}

          <div class="ls-cg__card-overlay"></div>

          <div class="ls-cg__card-text">
            {%- if block.settings.title != blank -%}
              <p class="ls-cg__card-title">{{ block.settings.title }}</p>
            {%- endif -%}

            {%- if block.settings.subtitle != blank -%}
              <p class="ls-cg__card-subtitle">{{ block.settings.subtitle }}</p>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- assign total_blocks = section.blocks.size -%}
    <div class="ls-cg__pagination">
      <button class="ls-cg__pagination-btn ls-cg__prev" aria-label="Previous">
        <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 1L1 5L5 9" stroke="#192534" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <span class="ls-cg__pagination-counter">
        <span class="ls-cg__current">1</span>/{{ total_blocks }}
      </span>
      <button class="ls-cg__pagination-btn ls-cg__next" aria-label="Next">
        <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 1L5 5L1 9" stroke="#192534" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="ls-cg__mobile-cta">
        <a class="ls-cg__button" href="{{ section.settings.button_link }}"
          {% if section.settings.button_link == blank %}role="link" aria-disabled="true"{% endif %}>
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function() {
    var mql = window.matchMedia('(max-width: 749px)');

    function initCarousel() {
      var section = document.querySelector('.ls-cg');
      if (!section) return;

      var grid = section.querySelector('.ls-cg__grid');
      var cards = grid.querySelectorAll('.ls-cg__card');
      var counter = section.querySelector('.ls-cg__current');
      var prevBtn = section.querySelector('.ls-cg__prev');
      var nextBtn = section.querySelector('.ls-cg__next');
      var total = cards.length;

      if (!grid || total === 0) return;

      function getCurrentIndex() {
        var scrollLeft = grid.scrollLeft;
        var cardWidth = cards[0].offsetWidth + 15; /* card width + gap */
        return Math.round(scrollLeft / cardWidth);
      }

      function updateCounter() {
        var idx = getCurrentIndex();
        counter.textContent = Math.min(idx + 1, total);
      }

      grid.addEventListener('scroll', updateCounter, { passive: true });

      prevBtn.addEventListener('click', function() {
        var cardWidth = cards[0].offsetWidth + 15;
        grid.scrollBy({ left: -cardWidth, behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', function() {
        var cardWidth = cards[0].offsetWidth + 15;
        grid.scrollBy({ left: cardWidth, behavior: 'smooth' });
      });
    }

    if (mql.matches) {
      initCarousel();
    }

    mql.addEventListener('change', function(e) {
      if (e.matches) initCarousel();
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        if (mql.matches) initCarousel();
      });
    }
  })();
</script>

{% schema %}
{
  "name": "LS Collection Grid",
  "tag": "section",
  "class": "ls-cg-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Every Keepsake, Made By Hand"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "max_blocks": 9,
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "size",
          "label": "Card size",
          "options": [
            { "value": "large", "label": "Large (2x2)" },
            { "value": "medium", "label": "Medium" },
            { "value": "small", "label": "Small" }
          ],
          "default": "small"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LS Collection Grid",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "title": "Commemorative Coins",
            "size": "large"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "Shadow Boxes",
            "size": "medium"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "Desktop Plaques & Night Lights",
            "size": "medium"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "Print Media",
            "subtitle": "Canvas, Metal, Wood",
            "size": "medium"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "Photo Puzzles",
            "size": "medium"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "Night Lights",
            "subtitle": "Kids & Baby",
            "size": "small"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "School Years",
            "subtitle": "Photo Frame",
            "size": "small"
          }
        },
        {
          "type": "collection_card",
          "settings": {

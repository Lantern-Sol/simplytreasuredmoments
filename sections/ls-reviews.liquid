                </svg>
              </span>
              <span class="ls-rev__verified-text">Verified purchase</span>
            </div>

            {%- if block.settings.review_text != blank -%}
              <p class="ls-rev__review-text">"{{ block.settings.review_text }}"</p>
            {%- endif -%}
          </div>
        {%- endfor -%}

        {%- if blocks_size > 1 -%}
          <div class="ls-rev__nav">
            <button class="ls-rev__nav-btn" data-rev-prev type="button" aria-label="Previous review">
              <svg viewBox="0 0 16 16"><path d="M10 4l-4 4 4 4"/></svg>
            </button>
            <button class="ls-rev__nav-btn" data-rev-next type="button" aria-label="Next review">
              <svg viewBox="0 0 16 16"><path d="M6 4l4 4-4 4"/></svg>
            </button>
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.button_label != blank -%}
        <div class="ls-rev__mobile-cta-wrap">
          <a
            class="ls-rev__mobile-cta"
            href="{{ section.settings.button_link }}"
            {% if section.settings.button_link == blank %}role="link" aria-disabled="true"{% endif %}
          >
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var container = document.querySelector('[data-reviews-slider]');
    if (!container) return;

    var slides = container.querySelectorAll('.ls-rev__slide');
    var images = container.querySelectorAll('.ls-rev__main-img');
    var thumbs = container.querySelectorAll('.ls-rev__thumb');
    var prevBtn = container.querySelector('[data-rev-prev]');
    var nextBtn = container.querySelector('[data-rev-next]');
    var imgSlider = container.querySelector('[data-rev-img-slider]');
    var imgSlides = imgSlider ? imgSlider.querySelectorAll('.ls-rev__img-slide') : [];
    var total = slides.length;
    if (total < 1) return;

    var current = 0;

    function goTo(index) {
      if (index < 0) index = total - 1;
      if (index >= total) index = 0;
      current = index;

      /* Update review text slides */
      slides.forEach(function (s, i) {
        s.style.display = i === current ? '' : 'none';
      });

      /* Update desktop main images */
      images.forEach(function (img, i) {
        img.style.opacity = i === current ? '1' : '0';
        img.style.position = i === current ? 'relative' : 'absolute';
        img.style.top = i === current ? '' : '0';
        img.style.left = i === current ? '' : '0';
      });

      /* Update desktop thumbnails */
      thumbs.forEach(function (t, i) {
        t.classList.toggle('is-active', i === current);
      });

      /* Scroll mobile image slider to the active slide */
      if (imgSlider && imgSlides.length > 0 && imgSlides[current]) {
        imgSlides[current].scrollIntoView({
          behavior: 'smooth',
          block: 'nearest',
          inline: 'start'
        });
      }
    }

    /* Stack desktop main images absolutely for transitions */
    if (images.length > 1) {
      var imgParent = images[0].parentElement;
      imgParent.style.position = 'relative';
      images.forEach(function (img, i) {
        if (i !== 0) {
          img.style.opacity = '0';
          img.style.position = 'absolute';
          img.style.top = '0';
          img.style.left = '0';
          img.style.width = '100%';
          img.style.height = '100%';
        }
      });
    }

    /* Nav button clicks */
    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); });

    /* Desktop thumbnail clicks */
    thumbs.forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        goTo(parseInt(this.getAttribute('data-thumb-index'), 10));
      });
    });

    /* Mobile image slider: sync review content on scroll */
    if (imgSlider && imgSlides.length > 1) {
      var scrollTimer = null;
      imgSlider.addEventListener('scroll', function () {
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(function () {
          var sliderLeft = imgSlider.scrollLeft;
          var closestIdx = 0;
          var closestDist = Infinity;
          imgSlides.forEach(function (slide, i) {
            var dist = Math.abs(slide.offsetLeft - imgSlider.offsetLeft - sliderLeft);
            if (dist < closestDist) {
              closestDist = dist;
              closestIdx = i;
            }
          });
          if (closestIdx !== current) {
            current = closestIdx;
            slides.forEach(function (s, i) {
              s.style.display = i === current ? '' : 'none';
            });
          }
        }, 80);
      });
    }
  })();
</script>


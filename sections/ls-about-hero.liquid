<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500&family=Nunito+Sans:wght@400;600;700&display=swap');

  .ls-about-hero {
    background: #FFFFFF;
  }

  /* ── Carousel ── */
  .ls-about-hero__carousel {
    grid-column: 1 / -1;
    position: relative;
    padding: 2rem 72px;
  }

  .ls-about-hero__carousel-mask {
    overflow: hidden;
    position: relative;
  }

  .ls-about-hero__carousel .swiper {
    overflow: visible;
    padding: 1rem 0;
    width: 100%;
  }

  .ls-about-hero__carousel .swiper-slide {
    width: 75vw;
    border-radius: 12px;
    overflow: hidden;
  }

  @media (min-width: 750px) {
    .ls-about-hero__carousel .swiper-slide { width: 300px; }
  }

  @media (min-width: 960px) {
    .ls-about-hero__carousel .swiper-slide { width: 480px; }
  }

  .ls-about-hero__carousel .swiper-slide img {
    display: block;
    width: 100%;
    aspect-ratio: 408 / 436;
    object-fit: cover;
    border-radius: 12px;
  }

  .ls-about-hero__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 45px;
    height: 45px;
    border-radius: 3px;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .ls-about-hero__nav:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  .ls-about-hero__nav svg {
    width: 25px;
    height: 25px;
    color: #192534;
  }

  .ls-about-hero__nav--prev {
    left: 0;
  }

  .ls-about-hero__nav--next {
    right: 0;
  }

  /* ── Text content ── */
  .ls-about-hero__content {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 35px 0 0;
    gap: 12px;
    max-width: 721px;
    margin: 0 auto;
    width: 100%;
  }

  .ls-about-hero__label {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: -0.13px;
    color: #192534;
    text-transform: uppercase;
    margin: 0;
  }

  .ls-about-hero__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 2rem;
    line-height: 1.2;
    color: #192534;
    margin: 0;
  }

  .ls-about-hero__body {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.5;
    color: #192534;
    margin: 0;
  }

  /* ── Stats ── */
  .ls-about-hero__stats-section {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding-top: 16px;
  }

  .ls-about-hero__stats-title {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 600;
    font-size: 16px;
    color: #192534;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .ls-about-hero__stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .ls-about-hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    position: relative;
    padding: 0 24px;
  }

  .ls-about-hero__stat + .ls-about-hero__stat::before {
    content: '';
    position: absolute;
    left: -5px;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 57px;
    background: #192534;
  }

  .ls-about-hero__stat-number {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 600;
    font-size: 2rem;
    letter-spacing: -0.44px;
    color: #192534;
    margin: 0;
    line-height: 1.2;
  }

  .ls-about-hero__stat-label {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    font-size: 12px;
    letter-spacing: -0.12px;
    color: #192534;
    margin: 0;
    white-space: nowrap;
  }

  @media screen and (max-width: 959px) {
    .ls-about-hero__carousel { padding-inline: 24px; }
  }

  /* ── Responsive — Mobile ── */
  @media (max-width: 749px) {
    .section.ls-about-hero {
      padding-top: var(--mobile-pt) !important;
      padding-bottom: var(--mobile-pb) !important;
    }

    .ls-about-hero__carousel {
      padding: 1.5rem 0;
    }

    .ls-about-hero__nav {
      width: 36px;
      height: 36px;
    }

    .ls-about-hero__nav svg {
      width: 20px;
      height: 20px;
    }

    .ls-about-hero__nav--prev {
      left: 0;
    }

    .ls-about-hero__nav--next {
      right: 0;
    }

    .ls-about-hero__content {
      padding: 1.5rem 0 0;
    }

    .ls-about-hero__heading {
      font-size: 30px;
      line-height: 38px;
    }

    .ls-about-hero__body {
      font-size: 15px;
    }

    .ls-about-hero__stats-title {
      font-size: 18px;
    }

    .ls-about-hero__stats {
      gap: 10px;
      flex-wrap: nowrap;
    }

    .ls-about-hero__stat {
      padding: 0 15px;
    }

    .ls-about-hero__stat-number {
      font-size: 28px;
    }

    .ls-about-hero__stat + .ls-about-hero__stat::before {
      left: -5px;
      height: 40px;
    }
  }

  /* ── Responsive — Desktop ── */
  @media (min-width: 960px) {
    .ls-about-hero__heading {
      font-size: 2.75rem;
      line-height: 48.4px;
    }

    .ls-about-hero__body {
      font-size: 18px;
      line-height: 27px;
    }

    .ls-about-hero__stats-title {
      font-size: 20px;
    }

    .ls-about-hero__stat-number {
      font-size: 2.75rem;
    }

    .ls-about-hero__stats {
      gap: 10px;
    }

    .ls-about-hero__stat + .ls-about-hero__stat::before {
      left: -5px;
    }
  }
</style>

<section
  class="section section--full-width ls-about-hero"
  style="
    --desktop-pt: {{ section.settings.padding_top }}px;
    --desktop-pb: {{ section.settings.padding_bottom }}px;
    --mobile-pt: {{ section.settings.mobile_padding_top }}px;
    --mobile-pb: {{ section.settings.mobile_padding_bottom }}px;
    padding-top: var(--desktop-pt);
    padding-bottom: var(--desktop-pb);
  "
>
  {%- assign slides = section.blocks | where: 'type', 'slide' -%}

  {%- if slides.size > 0 -%}
    <div class="ls-about-hero__carousel">
      <div class="ls-about-hero__carousel-mask">
        <div class="swiper ls-about-hero__swiper">
        <div class="swiper-wrapper">
          {%- for block in slides -%}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 900
                  | image_tag:
                    widths: '400, 600, 900',
                    sizes: '(min-width: 960px) 408px, 280px',
                    loading: 'eager',
                    alt: block.settings.image.alt | default: section.settings.heading
                }}
              {%- else -%}
                <div style="width: 100%; aspect-ratio: 408 / 436; background: #F0EDE8; border-radius: 12px;"></div>
              {%- endif -%}
            </div>
          {%- endfor -%}

          {%- comment -%}
            Duplicate slides for Swiper loop mode.
            slidesPerView:'auto' with coverflow needs ≥ 2×loopedSlides slides.
            Swiper calculates loopedSlides ~4, so we need ≥ 12 total.
            Repeat up to 3× to handle any original slide count.
          {%- endcomment -%}
          {%- comment -%}
            Duplicate slides for Swiper loop mode.
            Need ≥ 12 total slides for coverflow + loop to work smoothly.
          {%- endcomment -%}
          {%- if slides.size > 0 and slides.size < 12 -%}
            {%- assign iterations = 12 | divided_by: slides.size -%}
            {%- for i in (1..iterations) -%}
              {%- for block in slides -%}
                <div class="swiper-slide" aria-hidden="true">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 900 | image_tag: widths: '400, 600, 900', sizes: '(min-width: 960px) 408px, 280px', loading: 'lazy', alt: block.settings.image.alt | default: section.settings.heading }}
                  {%- else -%}
                    <div style="width: 100%; aspect-ratio: 408 / 436; background: #F0EDE8; border-radius: 12px;"></div>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      <button class="ls-about-hero__nav ls-about-hero__nav--prev" aria-label="Previous slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>

      <button class="ls-about-hero__nav ls-about-hero__nav--next" aria-label="Next slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 6 15 12 9 18"/>
        </svg>
      </button>
      </div>{%- comment -%} /.ls-about-hero__carousel-mask {%- endcomment -%}
    </div>
  {%- endif -%}

  <div class="ls-about-hero__content">
    {%- if section.settings.label != blank -%}
      <p class="ls-about-hero__label">{{ section.settings.label }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="ls-about-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.body_text != blank -%}
      <p class="ls-about-hero__body">{{ section.settings.body_text }}</p>
    {%- endif -%}

    <div class="ls-about-hero__stats-section">
      {%- if section.settings.stats_title != blank -%}
        <p class="ls-about-hero__stats-title">{{ section.settings.stats_title }}</p>
      {%- endif -%}

      <div class="ls-about-hero__stats">
        {%- if section.settings.stat_1_number != blank -%}
          <div class="ls-about-hero__stat">
            <p class="ls-about-hero__stat-number">{{ section.settings.stat_1_number }}</p>
            {%- if section.settings.stat_1_label != blank -%}
              <p class="ls-about-hero__stat-label">{{ section.settings.stat_1_label }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.stat_2_number != blank -%}
          <div class="ls-about-hero__stat">
            <p class="ls-about-hero__stat-number">{{ section.settings.stat_2_number }}</p>
            {%- if section.settings.stat_2_label != blank -%}
              <p class="ls-about-hero__stat-label">{{ section.settings.stat_2_label }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.stat_3_number != blank -%}
          <div class="ls-about-hero__stat">
            <p class="ls-about-hero__stat-number">{{ section.settings.stat_3_number }}</p>
            {%- if section.settings.stat_3_label != blank -%}
              <p class="ls-about-hero__stat-label">{{ section.settings.stat_3_label }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var sectionEl = document.querySelector('#shopify-section-{{ section.id }} .ls-about-hero__swiper');
    if (!sectionEl) return;

    function initSwiper() {
      if (typeof Swiper === 'undefined') return;
      if (sectionEl.querySelectorAll('.swiper-slide').length <= 1) return;

      new Swiper(sectionEl, {
        effect: 'coverflow',
        centeredSlides: true,
        slidesPerView: 'auto',
        loop: true,
        loopAdditionalSlides: 2,
        speed: 900,
        autoplay: {
          delay: 5000,
          disableOnInteraction: false
        },
        grabCursor: true,
        coverflowEffect: {
          rotate: 30,
          stretch: 217,
          depth: 100,
          modifier: 1,
          slideShadows: false
        },
        navigation: {
          prevEl: '.ls-about-hero__nav--prev',
          nextEl: '.ls-about-hero__nav--next'
        }
      });
    }

    /* Load Swiper CSS */
    if (!document.querySelector('link[href*="swiper"]')) {
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://unpkg.com/swiper@11/swiper-bundle.min.css';
      document.head.appendChild(link);
    }

    /* Load Swiper JS */
    if (typeof Swiper === 'undefined') {
      var script = document.createElement('script');
      script.src = 'https://unpkg.com/swiper@11/swiper-bundle.min.js';
      script.onload = initSwiper;
      document.head.appendChild(script);
    } else {
      initSwiper();
    }
  })();

</script>


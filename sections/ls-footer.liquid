<style>
  .ls-footer {
    background: #F8F7F7;
  }

  .ls-footer__inner {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    gap: 45px;
    padding: 33px 34px 20px;
  }

  /* ── Top row: logo + menus ── */
  .ls-footer__top {
    display: flex;
    gap: 200px;
    align-items: flex-start;
  }

  .ls-footer__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
    width: 330px;
    flex-shrink: 0;
  }

  .ls-footer__logo img {
    display: block;
    width: 200px;
    height: auto;
  }

  .ls-footer__social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
  }

  .ls-footer__social a {
    display: flex;
    align-items: center;
    color: #192534;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .ls-footer__social a:hover {
    opacity: 0.6;
  }

  .ls-footer__social svg {
    height: 14px;
    width: auto;
    fill: currentColor;
  }

  /* ── Menus ── */
  .ls-footer__menus {
    display: flex;
    gap: 40px;
    flex: 1 0 0;
    min-width: 0;
  }

  .ls-footer__menu-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ls-footer__menu-col:nth-child(1) { width: 250px; }
  .ls-footer__menu-col:nth-child(2) { width: 299px; }
  .ls-footer__menu-col:nth-child(3) { width: 181px; }

  .ls-footer__menu-heading {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: 1.5;
    letter-spacing: -0.16px;
    color: #192534;
    margin: 0;
  }

  .ls-footer__menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ls-footer__menu-list a {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 30.5px;
    color: #192534;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .ls-footer__menu-list a:hover {
    opacity: 0.6;
  }

  /* ── Bottom area ── */
  .ls-footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
  }

  .ls-footer__bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 40px;
    border-bottom: 0.5px solid #B8A898;
  }

  .ls-footer__payments {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ls-footer__payments .icon {
    height: 18px;
    width: auto;
  }

  .ls-footer__legal {
    display: flex;
    align-items: center;
    gap: 0;
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 600;
    font-size: 13px;
    line-height: 18.2px;
    color: #192534;
    white-space: nowrap;
  }

  .ls-footer__legal a {
    color: #192534;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .ls-footer__legal a:hover {
    opacity: 0.6;
  }

  .ls-footer__legal-separator {
    margin: 0 1.5em;
  }

  .ls-footer__copyright {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 600;
    font-size: 11px;
    line-height: 15.4px;
    color: #192534;
    text-align: center;
    width: 100%;
    margin: 0;
  }

  .ls-footer__copyright a {
    color: #192534;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .ls-footer__copyright a:hover {
    opacity: 0.6;
  }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    .ls-footer__inner {
      padding: 20px 24px;
      gap: 45px;
      align-items: center;
    }

    .ls-footer__top {
      flex-direction: column;
      gap: 35px;
      align-items: center;
      width: 100%;
    }

    .ls-footer__brand {
      width: auto;
      gap: 0;
    }

    .ls-footer__brand .ls-footer__social {
      display: none;
    }

    .ls-footer__logo img {
      width: 200px;
      max-width: 100%;
    }

    .ls-footer__menus {
      flex-direction: column;
      gap: 35px;
      align-items: center;
      width: 100%;
    }

    .ls-footer__menu-col {
      width: 100% !important;
      align-items: center;
      text-align: center;
    }

    .ls-footer__menu-heading {
      text-align: center;
    }

    .ls-footer__menu-list {
      text-align: center;
    }

    /* Social icons between menus and bottom on mobile */
    .ls-footer__social--mobile {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 23px;
    }

    .ls-footer__social--mobile a {
      display: flex;
      align-items: center;
      color: #192534;
      text-decoration: none;
    }

    .ls-footer__social--mobile svg {
      height: 14px;
      width: auto;
      fill: currentColor;
    }

    .ls-footer__bottom {
      gap: 15px;
      width: 100%;
    }

    .ls-footer__bottom-row {
      flex-direction: column-reverse;
      height: auto;
      border-bottom: none;
      gap: 30px;
    }

    .ls-footer__legal {
      font-weight: 400;
      font-size: 16px;
      line-height: 22px;
    }

    .ls-footer__payments {
      gap: 4px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .ls-footer__payments .icon {
      height: 21px;
    }

    .ls-footer__copyright {
      font-weight: 700;
      font-size: 11px;
    }
  }

  /* Desktop: hide mobile social */
  @media (min-width: 750px) {
    .ls-footer__social--mobile {
      display: none;
    }
  }
</style>

<footer class="section section--full-width ls-footer">
  <div class="ls-footer__inner">
    {%- comment -%} Top row: logo + social + menus {%- endcomment -%}
    <div class="ls-footer__top">
      <div class="ls-footer__brand">
        {%- if section.settings.logo != blank -%}
          <a href="{{ routes.root_url }}" class="ls-footer__logo">
            {{ section.settings.logo | image_url: width: 618 | image_tag: loading: 'lazy', alt: shop.name }}
          </a>
        {%- endif -%}

        <div class="ls-footer__social">

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500&family=Nunito+Sans:wght@400;600;700&display=swap');

  .ls-hiw__inner {
    grid-column: 2;
    background-color: #F2F0EE;
    border-radius: 0.5rem;
    padding: 1.875rem 1.5rem;
  }

  .ls-hiw__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 1.75rem;
    line-height: 1.15;
    color: #192534;
    text-align: center;
    text-transform: capitalize;
    margin: 0 0 1.5rem;
  }

  .ls-hiw__steps {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    align-items: center;
  }

  .ls-hiw__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 14.5rem;
  }

  .ls-hiw__step-image {
    width: 7rem;
    height: 7rem;
    margin-bottom: 0.75rem;
    flex-shrink: 0;
  }

  .ls-hiw__step-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ls-hiw__step-title {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.375;
    color: #192534;
    margin: 0 0 0.25rem;
  }

  .ls-hiw__step-text {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.375rem;
    color: #192534;
    margin: 0;
  }

  /* Desktop */
  @media (min-width: 60em) {
    .ls-hiw__inner {
      padding: 1.875rem 4.6875rem;
    }

    .ls-hiw__heading {
      font-size: 2rem;
      line-height: 2.3rem;
      margin-bottom: 2rem;
    }

    .ls-hiw__steps {
      flex-direction: row;
      justify-content: space-between;
      max-width: 67.125rem;
      margin: 0 auto;
    }

    .ls-hiw__step {
      width: 14.5rem;
    }
  }
</style>

<section
  class="section section--full-width ls-hiw"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="ls-hiw__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="ls-hiw__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="ls-hiw__steps">
      {%- for i in (1..3) -%}
        {%- assign image_key = 'step_' | append: i | append: '_image' -%}
        {%- assign title_key = 'step_' | append: i | append: '_title' -%}
        {%- assign text_key = 'step_' | append: i | append: '_text' -%}
        {%- assign step_image = section.settings[image_key] -%}
        {%- assign step_title = section.settings[title_key] -%}
        {%- assign step_text = section.settings[text_key] -%}

        {%- if step_title != blank or step_text != blank -%}
          <div class="ls-hiw__step">
            {%- if step_image != blank -%}
              <div class="ls-hiw__step-image">
                {{
                  step_image
                  | image_url: width: 224
                  | image_tag:
                    widths: '112, 224',
                    sizes: '112px',
                    loading: 'lazy',
                    alt: step_title
                }}
              </div>
            {%- else -%}
              <div class="ls-hiw__step-image" style="background: #E5E3E0; border-radius: 50%;"></div>
            {%- endif -%}

            {%- if step_title != blank -%}
              <p class="ls-hiw__step-title">{{ i }}. {{ step_title }}</p>
            {%- endif -%}

            {%- if step_text != blank -%}
              <p class="ls-hiw__step-text">{{ step_text }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "LS How It Works",
  "tag": "section",
  "class": "ls-hiw-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "header",
      "content": "Step 1"
    },
    {
      "type": "image_picker",
      "id": "step_1_image",
      "label": "Step 1 illustration"
    },
    {
      "type": "text",
      "id": "step_1_title",
      "label": "Step 1 title",
      "default": "Find the perfect gift for this moment"
    },
    {
      "type": "textarea",
      "id": "step_1_text",
      "label": "Step 1 description",
      "default": "Browse by occasion and choose the keepsake that fits the memory."
    },
    {
      "type": "header",
      "content": "Step 2"
    },
    {
      "type": "image_picker",
      "id": "step_2_image",
      "label": "Step 2 illustration"
    },
    {
      "type": "text",
      "id": "step_2_title",
      "label": "Step 2 title",
      "default": "Make it completely theirs"
    },
    {
      "type": "textarea",
      "id": "step_2_text",
      "label": "Step 2 description",
      "default": "Upload your photo, personalize the details, and see a live preview."
    },
    {
      "type": "header",
      "content": "Step 3"
    },
    {
      "type": "image_picker",
      "id": "step_3_image",
      "label": "Step 3 illustration"
    },
    {
      "type": "text",
      "id": "step_3_title",
      "label": "Step 3 title",
      "default": "We handcraft it. They treasure it forever"
    },
    {
      "type": "textarea",
      "id": "step_3_text",
      "label": "Step 3 description",
      "default": "UV-printed by hand in the USA. Made to last a lifetime."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "LS How It Works"
    }
  ]
}
{% endschema %}

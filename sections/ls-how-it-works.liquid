<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500&family=Nunito+Sans:wght@400;600;700&display=swap');

  .ls-hiw__inner {
    grid-column: 2;
    background-color: #F2F0EE;
    border-radius: 0.9375rem;
    padding: 1.5625rem;
  }

  .ls-hiw__heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 2rem;
    line-height: 2.3rem;
    color: #192534;
    text-align: center;
    text-transform: capitalize;
    margin: 0 0 0.9375rem;
  }

  .ls-hiw__steps {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: center;
  }

  .ls-hiw__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 14.5rem;
  }

  .ls-hiw__step-image {
    width: 7rem;
    height: 7rem;
    margin-bottom: 0.5rem;
    flex-shrink: 0;
  }

  .ls-hiw__step-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ls-hiw__step-title {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: #192534;
    margin: 0 0 0.125rem;
  }

  .ls-hiw__step-text {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.375rem;
    color: #192534;
    margin: 0;
  }

  @media (max-width: 749px) {
    .ls-hiw {
      padding-top: var(--mobile-pt) !important;
      padding-bottom: var(--mobile-pb) !important;
    }
  }

  /* Desktop */
  @media (min-width: 60em) {
    .ls-hiw__inner {
      padding: 1.875rem 4.6875rem;
    }

    .ls-hiw__heading {
      font-size: 2rem;
      line-height: 2.3rem;
      margin-bottom: 2rem;
    }

    .ls-hiw__steps {
      flex-direction: row;
      justify-content: space-between;
      max-width: 67.125rem;
      margin: 0 auto;
    }

    .ls-hiw__step {
      width: 14.5rem;
    }
  }
</style>

<section
  class="section section--full-width ls-hiw"
  style="
    --desktop-pt: {{ section.settings.padding_top }}px;
    --desktop-pb: {{ section.settings.padding_bottom }}px;
    --mobile-pt: {{ section.settings.mobile_padding_top }}px;
    --mobile-pb: {{ section.settings.mobile_padding_bottom }}px;
    padding-top: var(--desktop-pt);
    padding-bottom: var(--desktop-pb);
  "
>
  <div class="ls-hiw__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="ls-hiw__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="ls-hiw__steps">
      {%- for block in section.blocks -%}
        {%- if block.settings.title != blank or block.settings.text != blank -%}
          <div class="ls-hiw__step" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div class="ls-hiw__step-image">
                {{
                  block.settings.image
                  | image_url: width: 224
                  | image_tag:
                    widths: '112, 224',
                    sizes: '112px',
                    loading: 'lazy',
                    alt: block.settings.title
                }}
              </div>
            {%- else -%}
              <div class="ls-hiw__step-image" style="background: #E5E3E0; border-radius: 50%;"></div>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <p class="ls-hiw__step-title">{% if section.settings.show_step_numbers %}{{ forloop.index }}. {% endif %}{{ block.settings.title }}</p>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="ls-hiw__step-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "LS How It Works",
  "tag": "section",
  "class": "ls-hiw-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "checkbox",
      "id": "show_step_numbers",
      "label": "Show step numbers",
      "default": true
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Illustration"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LS How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Find the perfect gift for this moment",
            "text": "Browse by occasion and choose the keepsake that fits the memory."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Make it completely theirs",
            "text": "Upload your photo, personalize the details, and see a live preview."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "We handcraft it. They treasure it forever",
            "text": "UV-printed by hand in the USA. Made to last a lifetime."
          }
        }
      ]
    }
  ]
}
{% endschema %}

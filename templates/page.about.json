gradient_direction":"to top","padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{"text_9zC8TW":{"type":"text","name":"t:names.heading","settings":{"text":"<h2>Who we are<\/h2>","width":"fit-content","max_width":"normal","alignment":"left","type_preset":"h2","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"text_VBnaHW":{"type":"text","settings":{"text":"<p>We transform your most meaningful photos into beautifully crafted works of art that celebrate life’s special moments. Using advanced UV printing, premium materials, and thoughtful design, we create personalized photo displays that bring memories to life with vivid color, texture, and dimensional depth. From modern acrylic and metal prints to wood canvases, shadow boxes, illuminated displays, and keepsake gifts, each piece is carefully designed to turn your photos into lasting treasures.<br\/><br\/>Our mission is simple: help people preserve and celebrate the moments that matter most. Whether honoring faith, family, milestones, achievements or cherished memories, our personalized photo art is created to inspire, uplift, and bring joy to the spaces where life happens every day.<br\/><br\/>Discover beautifully created personalized photo art and custom photo gifts. Our collection includes: Shadow Box displays, canvas prints, wood photo art, metal photo prints, acrylic photo displays, illuminated desktop photo lights and custom photo keepsakes.. Our products are designed to do more than decorate-they are meant to preserve the moments that define our lives. Every order is created with care, attention to detail and a passion for helping people celebrate the stories behind their photos.<br\/>Because memories aren’t meant to stay on a phone-they deserve to be seen, shared, and cherished everyday.<br\/><\/p>","width":"fit-content","max_width":"none","alignment":"left","type_preset":"rte","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}}},"block_order":["text_9zC8TW","text_VBnaHW"]}},"block_order":["image_MDCHie","group_7wtAVR"],"name":"t:names.image_with_text","settings":{"content_direction":"row","vertical_on_mobile":true,"horizontal_alignment":"flex-start","vertical_alignment":"center","align_baseline":false,"horizontal_alignment_flex_direction_column":"flex-start","vertical_alignment_flex_direction_column":"center","gap":32,"section_width":"page-width","section_height":"","section_height_custom":50,"color_scheme":"","background_media":"none","video_position":"cover","background_image_position":"cover","border":"none","border_width":1,"border_opacity":100,"border_radius":0,"toggle_overlay":false,"overlay_color":"#00000026","overlay_style":"solid","gradient_direction":"to top","padding-block-start":40,"padding-block-end":40}},"1775224005283bd4f6":{"type":"_blocks","blocks":{"text_BPRRYK":{"type":"text","name":"t:names.heading","settings":{"text":"<h2>Why choose us<\/h2>","width":"fit-content","max_width":"normal","alignment":"left","type_preset":"h2","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"ai_gen_block_5211535_XL7F4K":{"type":"ai_gen_block_5211535","settings":{
    "ls_contact_hero": {
      "type": "ls-contact-hero",
      "blocks": {
        "faq_1": { "type": "faq", "settings": { "question": "How do I place a custom order?", "answer": "Simply choose your product, upload your photo, and add any custom text. Our team will review your order and begin handcrafting your keepsake." } },
        "faq_2": { "type": "faq", "settings": { "question": "Can I customize the text on my keepsake?", "answer": "Yes! Most of our products allow you to add custom text such as names, dates, or short messages. You'll see the customization options on each product page." } },
        "faq_3": { "type": "faq", "settings": { "question": "What type of photo should I upload?", "answer": "For the best results, use a high-resolution photo with good lighting. Close-up portraits and well-lit images produce the sharpest details on our keepsakes." } },
        "faq_4": { "type": "faq", "settings": { "question": "Can I see a preview before my order is made?", "answer": "We provide a digital proof for certain products before production begins. You'll receive it via email for your approval." } },
        "faq_5": { "type": "faq", "settings": { "question": "Can I cancel or change my order after it's placed?", "answer": "We begin processing orders quickly. If you need to make a change, contact us within 2 hours of placing your order and we'll do our best to accommodate." } },
        "faq_6": { "type": "faq", "settings": { "question": "Do you offer bulk or wholesale orders?", "answer": "Yes, we offer bulk pricing for events, corporate gifts, and resellers. Please reach out to our team with your requirements for a custom quote." } },
        "faq_7": { "type": "faq", "settings": { "question": "What file formats do you accept for photos?", "answer": "We accept JPG, PNG, and HEIC files. For best quality, upload images that are at least 1000x1000 pixels." } },
        "faq_8": { "type": "faq", "settings": { "question": "Can I order a product without personalization?", "answer": "Some of our products are available without customization. Check the product page for available options." } },
        "faq_9": { "type": "faq", "settings": { "question": "How do I track my order?", "answer": "Once your order ships, you'll receive a confirmation email with a tracking number. You can also check your order status in your account dashboard." } },
        "faq_10": { "type": "faq", "settings": { "question": "Is there a minimum order quantity?", "answer": "No minimum! You can order a single personalized keepsake or as many as you'd like." } },
        "faq_11": { "type": "faq", "settings": { "question": "Do you offer rush orders?", "answer": "We offer expedited processing for an additional fee. Select the rush option at checkout or contact us for availability." } },
        "faq_12": { "type": "faq", "settings": { "question": "Can I add a gift message to my order?", "answer": "Yes! During checkout you can include a personalized gift message that will be printed on a card and included with your order." } },
        "faq_13": { "type": "faq", "settings": { "question": "What happens if I upload a low-quality photo?", "answer": "Our team will review your photo and reach out if it doesn't meet our quality standards. We'll work with you to find the best image for your keepsake." } },
        "faq_14": { "type": "faq", "settings": { "question": "Do you offer gift wrapping?", "answer": "We offer beautiful gift-ready packaging on select items. Look for the gift wrap option at checkout." } },
        "faq_15": { "type": "faq", "settings": { "question": "Can I reorder a previous design?", "answer": "Yes! If you've ordered before, contact us with your previous order number and we can recreate it or use the same design for a new product." } },
        "faq_16": { "type": "faq", "settings": { "question": "How do I apply a discount code?", "answer": "Enter your discount code in the promo field at checkout. The discount will be applied to your order total before payment." } },
        "faq_17": { "type": "faq", "settings": { "question": "How long does shipping take?", "answer": "Most orders ship within 3–5 business days. Custom and personalized items may take a bit longer as they are handcrafted to order." } },
        "faq_18": { "type": "faq", "settings": { "question": "Do you ship internationally?", "answer": "Yes, we ship to most countries worldwide. International shipping typically takes 7–14 business days depending on your location." } },
        "faq_19": { "type": "faq", "settings": { "question": "How long does production take?", "answer": "Production time varies by product. Most custom items take 2–4 business days to create before shipping. You'll see estimated timelines on each product page." } },
        "faq_20": { "type": "faq", "settings": { "question": "Is shipping free?", "answer": "We offer free standard shipping on orders over $50 within the United States. International and expedited shipping rates are calculated at checkout." } },
        "faq_21": { "type": "faq", "settings": { "question": "What if my package is lost or damaged?", "answer": "If your package is lost or arrives damaged, contact us immediately. We'll file a claim and send a replacement at no extra cost." } },
        "faq_22": { "type": "faq", "settings": { "question": "What materials are your keepsakes made from?", "answer": "Our products are crafted from premium materials including high-grade acrylic, natural wood, and museum-quality photo paper. Each material is chosen for durability and beauty." } },
        "faq_23": { "type": "faq", "settings": { "question": "How do I care for my keepsake?", "answer": "Gently dust with a soft, dry cloth. Avoid direct sunlight for extended periods to preserve colors. Acrylic items can be cleaned with a microfiber cloth." } },
        "faq_24": { "type": "faq", "settings": { "question": "Are your products eco-friendly?", "answer": "We prioritize sustainable materials and processes wherever possible. Our packaging is recyclable and we're continuously working to reduce our environmental footprint." } },
        "faq_25": { "type": "faq", "settings": { "question": "What sizes are available?", "answer": "Sizes vary by product. Each product page lists all available size options with detailed dimensions to help you choose the perfect fit." } },
        "faq_26": { "type": "faq", "settings": { "question": "What is your return policy?", "answer": "We offer a 60-day satisfaction guarantee. If you're not happy with your purchase, contact us and we'll arrange a replacement or full refund." } },
        "faq_27": { "type": "faq", "settings": { "question": "What if I'm unhappy with my order?", "answer": "We want you to love your keepsake. If something isn't right, reach out within 60 days and we'll make it right with a replacement or full refund." } },
        "faq_28": { "type": "faq", "settings": { "question": "Can I exchange my item for a different product?", "answer": "Yes, we accept exchanges within 60 days. Contact our support team to arrange the exchange and we'll guide you through the process." } },
        "faq_29": { "type": "faq", "settings": { "question": "How long do refunds take to process?", "answer": "Once we receive your return, refunds are processed within 3–5 business days. It may take an additional 5–10 days for your bank to reflect the credit." } },
        "faq_30": { "type": "faq", "settings": { "question": "Can I resell your products?", "answer": "We offer a wholesale program for authorized resellers. Contact our team to learn about partnership opportunities and wholesale pricing." } },
        "faq_31": { "type": "faq", "settings": { "question": "Do you offer white-label products?", "answer": "Yes, we offer white-label solutions for businesses. Reach out to discuss custom branding and packaging options for your brand." } },
        "faq_32": { "type": "faq", "settings": { "question": "Can I sell on marketplaces like Etsy with your products?", "answer": "Our wholesale partners are welcome to sell on third-party marketplaces. Contact us for details about our marketplace seller program." } },
        "faq_33": { "type": "faq", "settings": { "question": "How are your keepsakes made?", "answer": "Each keepsake is individually handcrafted by our team. We use professional-grade printing technology combined with skilled hand-finishing to ensure every piece meets our quality standards." } },
        "faq_34": { "type": "faq", "settings": { "question": "Do you do quality checks before shipping?", "answer": "Every single item goes through a multi-point quality inspection before it's packaged and shipped. We check print quality, color accuracy, and finishing details." } },
        "faq_35": { "type": "faq", "settings": { "question": "What printing technology do you use?", "answer": "We use UV-cured printing and dye-sublimation depending on the product. Both methods produce vivid, long-lasting colors that won't fade over time." } },
        "faq_36": { "type": "faq", "settings": { "question": "Do I need an account to place an order?", "answer": "No, you can checkout as a guest. However, creating an account lets you track orders, save designs, and reorder more easily." } },
        "faq_37": { "type": "faq", "settings": { "question": "How do I reset my password?", "answer": "Click 'Forgot Password' on the login page and enter your email. You'll receive a reset link within a few minutes." } },
        "faq_38": { "type": "faq", "settings": { "question": "Can I view my order history?", "answer": "Yes! Log into your account and visit the 'Orders' section to see all your past purchases, tracking info, and reorder options." } }
      },
